{
  "name": "calendarfr",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "web",
    "server"
  ],
  "scripts": {
    "agentops:report": "tsx scripts/agentops/index.ts",
    "dev": "concurrently --kill-others-on-fail --prefix \"[{name}]\" --names \"WEB,API\" \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "npm --workspace web run dev",
    "dev:server": "npm --workspace server run dev",
    "typecheck": "npm --workspaces --if-present run typecheck",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit",
    "test:e2e:real": "playwright test --project=real",
    "test:e2e:smoke": "playwright test --project=smoke",
    "build": "npm --workspace web run build",
    "build-storybook": "npm --workspace web run build-storybook",
    "storybook": "npm --workspace web run storybook",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8",
    "@commitlint/config-conventional": "^19.8",
    "@eslint/js": "^9.16",
    "@playwright/test": "^1.49",
    "@swc/core": "^1.10",
    "@swc/jest": "^0.2",
    "@testing-library/jest-dom": "^6.6",
    "@testing-library/react": "^16.3",
    "@testing-library/user-event": "^14.5",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.17",
    "concurrently": "^9.2",
    "eslint": "^9.16",
    "eslint-import-resolver-typescript": "^3.7",
    "eslint-plugin-import": "^2.31",
    "eslint-plugin-jsx-a11y": "^6.10",
    "eslint-plugin-react": "^7.37",
    "eslint-plugin-react-hooks": "^5.0",
    "eslint-plugin-react-refresh": "^0.4",
    "husky": "^9.1",
    "identity-obj-proxy": "^3.0",
    "jest": "^29.7",
    "jest-environment-jsdom": "^29.7",
    "js-yaml": "^4.1.1",
    "lint-staged": "^15.2",
    "msw": "^2.7",
    "prettier": "^3.4",
    "tsx": "^4.19",
    "typescript": "^5.6",
    "typescript-eslint": "^8.18",
    "undici": "^7.3"
  }
}
