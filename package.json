{
  "name": "calendarfr",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "web",
    "server",
    "shared"
  ],
  "scripts": {
    "agentops:report": "npx agentops report",
    "mutation": "STRYKER_RUN=1 stryker run",
    "type-coverage": "type-coverage --strict --detail --at-least 95 --reportSemanticError",
    "arch:check": "depcruise --config .dependency-cruiser.cjs --output-type err web/src/ server/src/ test-utils/",
    "arch:graph": "depcruise --config .dependency-cruiser.cjs --output-type mermaid web/src/ server/src/ test-utils/ > docs/architecture/dependency-graph.md",
    "dev": "concurrently --kill-others-on-fail --prefix \"[{name}]\" --names \"WEB,API\" \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "npm --workspace web run dev",
    "dev:server": "npm --workspace server run dev",
    "typecheck": "npm --workspaces --if-present run typecheck",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit",
    "test:e2e:real": "playwright test --project=real",
    "test:e2e:smoke": "playwright test --project=smoke",
    "build": "npm --workspace web run build",
    "build-storybook": "npm --workspace web run build-storybook",
    "storybook": "npm --workspace web run storybook",
    "prepare": "husky"
  },
  "typeCoverage": {
    "atLeast": 95,
    "strict": true,
    "ignoreFiles": [
      "**/*.test.ts",
      "**/__fixtures__/**"
    ]
  },
  "devDependencies": {
    "@ai-squad/agentops": "^0.1.0",
    "@commitlint/cli": "^19.8",
    "@commitlint/config-conventional": "^19.8",
    "@eslint/js": "^9.16",
    "@playwright/test": "^1.49",
    "@stryker-mutator/core": "^8.5",
    "@stryker-mutator/jest-runner": "^8.5",
    "@stryker-mutator/typescript-checker": "^8.5",
    "@swc/core": "^1.10",
    "@swc/jest": "^0.2",
    "@testing-library/dom": "^10.4",
    "@testing-library/jest-dom": "^6.6",
    "@testing-library/react": "^16.3",
    "@testing-library/user-event": "^14.5",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.17",
    "concurrently": "^9.2",
    "dependency-cruiser": "^16.6",
    "eslint": "^9.16",
    "eslint-import-resolver-typescript": "^3.7",
    "eslint-plugin-import": "^2.31",
    "eslint-plugin-jsx-a11y": "^6.10",
    "eslint-plugin-react": "^7.37",
    "eslint-plugin-react-hooks": "^5.0",
    "eslint-plugin-react-refresh": "^0.4",
    "husky": "^9.1",
    "identity-obj-proxy": "^3.0",
    "jest": "^29.7",
    "jest-environment-jsdom": "^29.7",
    "js-yaml": "^4.1.1",
    "lint-staged": "^15.2",
    "marked": "^14.1.4",
    "msw": "^2.7",
    "prettier": "^3.4",
    "ts-jest": "^29.2",
    "tsx": "^4.19",
    "type-coverage": "^2.29",
    "typescript": "^5.6",
    "typescript-eslint": "^8.18",
    "undici": "^7.3"
  }
}
