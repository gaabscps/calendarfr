# CalendárioFR — environment variables template
# Copy to .env (gitignored) and fill in real values.

# === Backend (Supabase CLI + ETL script — never in browser bundle) ===
# Find PROJECT_ID and ANON_KEY at https://supabase.com/dashboard/project/<ref>/settings/api
SUPABASE_PROJECT_ID=
# DB password set when project was created (Settings → Database)
SUPABASE_DB_PASSWORD=
SUPABASE_ANON_KEY=
# Service role bypasses RLS — used ONLY by scripts/migrate-to-supabase.ts (FEAT-030)
SUPABASE_SERVICE_ROLE_KEY=

# Access token for Supabase CLI (Settings → API → Access tokens)
SUPABASE_ACCESS_TOKEN=

# === Frontend (Vite — exposed to browser bundle) ===
# URL is derived from PROJECT_ID: https://<PROJECT_ID>.supabase.co
VITE_SUPABASE_URL=
# Copy of SUPABASE_ANON_KEY above (anon-key is safe to expose with RLS enabled)
VITE_SUPABASE_ANON_KEY=
