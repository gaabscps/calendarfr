# Dependencies
node_modules/

# Build outputs
dist/
build/
coverage/
.next/
.swc/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.log

# Env
.env
.env.local
.env.*.local
.env.e2e

# App data (planner days)
data/

# Brainstorming companion
.superpowers/

# SDD pipeline state (per-feature; framework-internal)
.agent-session/

# Test artifacts
playwright-report/
test-results/

# Stale tsc emits in TypeScript source trees (sources são .ts/.tsx; configs ficam .js/.mjs)
web/src/**/*.js
test-utils/**/*.js
!web/src/**/*.config.js
!test-utils/**/*.config.js
!web/src/**/*.config.mjs
!test-utils/**/*.config.mjs

# Workspace build outputs (workspace-scoped to avoid matching root dist/ twice)
web/dist/
server/dist/

# Storybook static build
storybook-static/

# Bundler / tool caches
**/.cache/
**/.vite/
**/.swc/
**/*.tsbuildinfo

# Quality tool reports (gitignored — only docs/agentops/ aggregates are committed)
reports/

# Test tmpdir leaks (macOS os.tmpdir() inside relative cwd) and accidental package manager artifacts
var/
yarn.lock

# ai-squad per-repo hook install (managed by `ai-squad deploy`)
.claude/hooks/
docs/superpowers/